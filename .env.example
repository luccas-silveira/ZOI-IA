# Exemplo de variáveis de ambiente para IA‑ZOI

# Credenciais do GoHighLevel (substitua pelos seus valores reais)
GHL_CLIENT_ID=your_client_id_here
GHL_CLIENT_SECRET=your_client_secret_here
GHL_AUTH_CODE=your_authorization_code_here
GHL_USER_TYPE=Company

# Localização alvo para sincronização de usuários e campos personalizados
# GHL_LOCATION_ID=citQs4acsN1StzOEDuvj

# Credenciais do OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_BASE=https://api.openai.com/v1

# Configurações do servidor Flask
FLASK_HOST=0.0.0.0
FLASK_PORT=5050
FLASK_DEBUG=True